[sqlfluff]
dialect = postgres
templater = jinja
sql_file_exts = .sql
exclude_rules = RF05
max_line_length = 120

[sqlfluff:templater:jinja]
apply_dbt_builtins = true

[sqlfluff:templater:jinja:macros]
normalize_date = "{% macro normalize_date(col) %}cast({{ col }} as date){% endmacro %}"
extract_income = "{% macro extract_income(col, type) %}NULL{% endmacro %}"
format_wttj_salary = "{% macro format_wttj_salary(col) %}{{ col }}{% endmacro %}"
normalize_experience = "{% macro normalize_experience(col) %}{{ col }}{% endmacro %}"
normalize_city = "{% macro normalize_city(col) %}{{ col }}{% endmacro %}"
categorize_experience = "{% macro categorize_experience(col) %}{{ col }}{% endmacro %}"

[sqlfluff:indentation]
indent_unit = space
tab_space_size = 4

[sqlfluff:layout:type:comma]
line_position = trailing
