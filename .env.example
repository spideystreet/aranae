# --------------------------------------------------

# [ DATABASE CONFIGURATION ]
# Default credentials for local development via Docker
POSTGRES_USER="aranae_user"
POSTGRES_PASSWORD="aranae_password"
POSTGRES_DB="aranae_db"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5434"

# [ DBT ORCHESTRATION ]
# Directory where profiles.yml is located
DBT_PROFILES_DIR="./dbt"
# Schema where RAW ingestion tables are stored
DBT_RAW_SCHEMA="source"

# [ OPTIONAL SERVICES ]
# Mistral AI for advanced data refinement (if needed)
MISTRAL_API_KEY="your_mistral_key_here"

# OpenRouter (alternative LLM provider)
OPENROUTER_API_KEY="your_openrouter_key_here"

# --------------------------------------------------
# GitHub — Personal Access Token for MCP GitHub server
GITHUB_TOKEN="your_github_personal_access_token_here"
