# [ DATABASE CONFIGURATION ]
# Default credentials for local development via Docker
POSTGRES_USER=synapse_user
POSTGRES_PASSWORD=synapse_password
POSTGRES_DB=synapse_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5434

# [ DBT ORCHESTRATION ]
# Directory where profiles.yml is located
DBT_PROFILES_DIR=./dbt

# [ OPTIONAL SERVICES ]
# Mistral AI for advanced data refinement (if needed)
MISTRAL_API_KEY=your_mistral_key_here

# [ SYSTEM SETTINGS ]
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --------------------------------------------------
# CRITICAL: Do not commit your real .env file!
# --------------------------------------------------
